EXCHANGE=binance
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Bankroll in account quote currency (USDT)
BANKROLL_USDT=1000
BANKROLL_MODE=static
BANKROLL_COMPOUNDING=false
BANKROLL_MIN_USDT=50
BANKROLL_MAX_USDT=0
BANKROLL_SYNC_INTERVAL_SEC=900

# Risk defaults
MAX_RISK_PER_TRADE_PCT=1.5
MAX_DAILY_DRAWDOWN_PCT=3
MAX_CONCURRENT_POSITIONS=2
SPLIT_RISK_ACROSS_SLOTS=true
MAX_PORTFOLIO_RISK_PCT=1.5
# Below the portfolio cap on purpose: two same-direction alt positions are
# effectively one levered BTC-beta bet, so cap them tighter than the total.
MAX_SAME_DIRECTION_RISK_PCT=1.0
MIN_ENTRY_RISK_PCT=0.25
# net = wins offset losses before the daily kill switch trips (standard);
# losses_only = gross losses trip it even on a net-green day (stricter)
DAILY_DRAWDOWN_MODE=net
# Scale position risk down (never up) for low-confidence signals
CONFIDENCE_RISK_SCALING=true
CONFIDENCE_FULL_RISK_AT=0.6
MIN_STOP_COST_MULTIPLE=5
DEFAULT_LEVERAGE=3
MAX_LEVERAGE=5
RISK_TIER_MODE=auto
RISK_BASE_PCT=1.0
RISK_RECOVERY_PCT=0.75
RISK_DRAWDOWN_PCT=0.5
RISK_PROVEN_PCT=1.5
RISK_RECOVERY_DRAWDOWN_PCT=2.0
RISK_DRAWDOWN_TRIGGER_PCT=5.0
RISK_PROVEN_MIN_TRADES=50
RISK_PROVEN_MIN_EXPECTANCY_R=0.15
RISK_PROVEN_MIN_PROFIT_FACTOR=1.3
RISK_PROVEN_MAX_DRAWDOWN_PCT=8.0
RISK_PROVEN_MIN_SYMBOLS=3
REENTRY_MAX_TRADES_PER_SYMBOL_PER_DAY=3
REENTRY_MIN_EV_MULTIPLIER=1.5

# Strategy profile — which modules may affect a trade decision.
#   baseline_simple (default): base signal + MTF + cost/risk gates decide;
#     SMC/news/memory/adaptive observe & log but cannot change the decision.
#   full_agentic: the full stack (previous behavior).
#   smc_observe / memory_observe: baseline with extra ablation logging.
STRATEGY_PROFILE=baseline_simple

# Cost-aware entry gate
TAKER_FEE_PCT=0.05
SLIPPAGE_PCT=0.03
MIN_LIVE_EV_R=0.25
MIN_EDGE_AFTER_COST_R=0.15
# Extra cost/edge rejection gates (reject-only, never change position size)
MAX_ESTIMATED_COST_R=0.20
MIN_NET_EV_AFTER_COST_R=0.25
MIN_EXPECTED_REWARD_COST_MULTIPLE=5

# Daily coin digest
COIN_DIGEST_HOUR_PH=21

# Free, no-auth news context (cryptocurrency.cv) — display/sentiment-nudge
# only, never opens trades on its own.
NEWS_ENABLED=true
NEWS_PROVIDER=cryptocurrency_cv
NEWS_API_URL=https://cryptocurrency.cv/api/news
NEWS_TIMEOUT_SEC=8
NEWS_MAX_HEADLINES=5

# Dynamic two-stage market scanner — stage 1 is one cheap ticker-scan call
# across the exchange; only the shortlisted top N get the full strategy stack
DYNAMIC_MARKET_SCAN=true
MARKET_SCAN_TOP_N=30
MARKET_SCAN_MIN_QUOTE_VOLUME=50000000
MARKET_SCAN_MAX_SPREAD_PCT=0.15
MARKET_SCAN_REFRESH_MINUTES=60
MARKET_SCAN_EXCLUDE_SYMBOLS=USDC/USDT,TUSD/USDT,FDUSD/USDT
MARKET_SCAN_INCLUDE_FIXED_MAJORS=true
MARKET_SCAN_FIXED_MAJORS=BTC/USDT,ETH/USDT,SOL/USDT,XRP/USDT,ADA/USDT
# Market-cap/rank filter (CoinGecko, free/no-key) — excludes micro-caps and
# synthetic index/dominance products (e.g. BTCDOM) that can clear the volume
# floor but aren't real established coins. Degrades to volume-only filtering
# if the API is unavailable.
MARKET_SCAN_REQUIRE_MARKET_CAP_RANK=true
MARKET_SCAN_MIN_MARKET_CAP_RANK=150
MARKET_SCAN_MARKET_CAP_API_URL=https://api.coingecko.com/api/v3/coins/markets
MARKET_SCAN_MARKET_CAP_REFRESH_HOURS=12

# Dashboard auth
WEBAPI_PASSWORD_HASH=
WEBAPI_SECRET_KEY=
