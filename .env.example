EXCHANGE=binance
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Bankroll in account quote currency (USDT)
BANKROLL_USDT=1000
BANKROLL_MODE=static
BANKROLL_COMPOUNDING=false
BANKROLL_MIN_USDT=50
BANKROLL_MAX_USDT=0
BANKROLL_SYNC_INTERVAL_SEC=900

# Risk defaults
MAX_RISK_PER_TRADE_PCT=1.5
MAX_DAILY_DRAWDOWN_PCT=3
MAX_CONCURRENT_POSITIONS=2
SPLIT_RISK_ACROSS_SLOTS=true
MAX_PORTFOLIO_RISK_PCT=1.5
MAX_SAME_DIRECTION_RISK_PCT=1.5
MIN_ENTRY_RISK_PCT=0.25
MIN_STOP_COST_MULTIPLE=5
DEFAULT_LEVERAGE=3
MAX_LEVERAGE=5
RISK_TIER_MODE=auto
RISK_BASE_PCT=1.0
RISK_RECOVERY_PCT=0.75
RISK_DRAWDOWN_PCT=0.5
RISK_PROVEN_PCT=1.5
RISK_RECOVERY_DRAWDOWN_PCT=2.0
RISK_DRAWDOWN_TRIGGER_PCT=5.0
RISK_PROVEN_MIN_TRADES=50
RISK_PROVEN_MIN_EXPECTANCY_R=0.15
RISK_PROVEN_MIN_PROFIT_FACTOR=1.3
RISK_PROVEN_MAX_DRAWDOWN_PCT=8.0
RISK_PROVEN_MIN_SYMBOLS=3
REENTRY_MAX_TRADES_PER_SYMBOL_PER_DAY=3
REENTRY_MIN_EV_MULTIPLIER=1.5

# Cost-aware entry gate
TAKER_FEE_PCT=0.05
SLIPPAGE_PCT=0.03
MIN_LIVE_EV_R=0.25
MIN_EDGE_AFTER_COST_R=0.15

# Dashboard auth
WEBAPI_PASSWORD_HASH=
WEBAPI_SECRET_KEY=
