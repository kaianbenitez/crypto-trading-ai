[Unit]
Description=Crypto Trading AI — FastAPI Backend
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/trading-ai
Environment=PYTHONPATH=/root/trading-ai
EnvironmentFile=/root/trading-ai/.env
ExecStart=/root/trading-ai/venv/bin/uvicorn webapi.main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
